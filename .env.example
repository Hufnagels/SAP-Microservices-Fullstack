# Copy to .env and fill in real values
# cp .env.example .env

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=<guest>

# ── Auth Service ────────────────────────────────────────────────────────────
# IMPORTANT: change this in production (min 32 chars)
JWT_SECRET=change-me-in-production-at-least-256-bits-long
JWT_EXPIRE_HOURS=8

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=<guest>
RABBITMQ_DEFAULT_PASS=<guest>

# ── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=<guest>
GRAFANA_ADMIN_PASSWORD=<guest>

# ── SAP B1 Adapter ──────────────────────────────────────────────────────────
SAP_B1_SERVICE_LAYER_URL=https://<SAP_B1_SERVICE_LAYER_IP>:50000/b1s
SAP_B1_COMPANY_DB=TEST_DB
SAP_B1_USERNAME=<guest>
SAP_B1_PASSWORD=

# ── SAP → MSSQL ─────────────────────────────────────────────────────────────
DST_SQL_SERVER=192.168.10.109,1433
DST_SQL_DB=ReportingDB
DST_SQL_USER=sa
DST_SQL_PASSWORD=

# ── Auth Bootstrap (first-run admin, only creates if DB is empty) ─────────
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=secret123

# ── Labeling Service — CAB SQUIX printer ────────────────────────────────────
PRINTER_IP=<192.168.1.100>
PRINTER_PORT=9100
